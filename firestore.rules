rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Профілі користувачів — статистика, аватар, історія, закладки
    // Читати можуть усі залогінені (потрібно для глобального рейтингу),
    // писати може тільки власник свого документа
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Пости спільноти (community chat)
    // Читати можуть усі залогінені, створювати повідомлення теж,
    // редагувати/видаляти може тільки автор
    match /community_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // За замовчуванням — все інше заборонено
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
